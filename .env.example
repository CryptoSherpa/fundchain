SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=your_wallet_private_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Optional: fee recipient / contract owner. If unset (or 0x0...), the contract's
# constructor falls back to msg.sender — i.e. the deployer wallet. Set to a
# multisig / cold wallet for mainnet so platform fees don't accumulate on the
# hot deployer key.
OWNER_ADDRESS=
