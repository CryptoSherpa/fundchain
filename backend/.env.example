# --- Hardhat / RPC ---
RPC_URL=http://127.0.0.1:8545
CONTRACT_ADDRESS=your_deployed_contract_address

# Signer used by the backend to submit donate()/createCampaign() txs on behalf
# of AI agents. For local testing, use a Hardhat pre-funded test account.
PRIVATE_KEY=your_wallet_private_key

# --- Server ---
PORT=3001

# --- x402 ---
# Address that receives x402 micropayments (advertised in 402 responses).
OWNER_ADDRESS=your_owner_wallet_address
# Set FACILITATOR_URL to enable real x402-express settlement. Leaving it
# empty runs the backend in demo mode: it serves HTTP 402 + requirements
# headers per the protocol but does not verify the X-PAYMENT header on-chain.
FACILITATOR_URL=
X402_NETWORK=base-sepolia
