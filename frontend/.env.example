# ─── Pinata IPFS JWT ─────────────────────────────────────────────────────────
# SECURITY WARNING: Vite inlines any VITE_*-prefixed variable into the CLIENT
# bundle at build time. This value IS visible to anyone who opens the built
# app's .js file or DevTools. For production:
#   • Mint a NARROW-SCOPE JWT limited to pinFileToIPFS with a low upload quota.
#   • Or move image upload behind your Express backend so the JWT stays
#     server-side — the frontend POSTs the file to the backend, which forwards
#     to Pinata. Recommended for public deployments.
VITE_PINATA_JWT=your_pinata_jwt_here

# ─── Optional: backend base URL ──────────────────────────────────────────────
# Defaults to http://localhost:3001 if unset. Override for production.
# VITE_API_BASE=https://api.your-domain.com

# ─── Arweave wallet JWK (stringified JSON) ───────────────────────────────────
# Not currently consumed by the app; retained for future migration back to
# Arweave/Irys. SAME SECURITY WARNING APPLIES — do not put a funded wallet's
# JWK here if you ship a public build.
VITE_ARWEAVE_KEY=
